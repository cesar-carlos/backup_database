APP_NAME=Backup Database
APP_VERSION=3.5.0
DEBUG_MODE=true
AUTO_UPDATE_FEED_URL=https://raw.githubusercontent.com/cesar-carlos/backup_database/main/appcast.xml

# Single Instance Control
# Set to 'false' to allow multiple instances (useful for development/testing)
# Default: true (only one instance allowed)
SINGLE_INSTANCE_ENABLED=true

# UI scheduler fallback when Windows Service status cannot be checked
# fail_open: start local scheduler (default)
# fail_safe: do not start local scheduler
UI_SCHEDULER_FALLBACK_MODE=fail_open

# Debug only: App mode override (server | client)
# Used when running from IDE / flutter run. Ignored in release builds.
# Example: DEBUG_APP_MODE=client to test client UI without reinstalling.
DEBUG_APP_MODE=server

# ----------------------------------------------------------------------------
# License Configuration (v2 Ed25519)
# ----------------------------------------------------------------------------
# Public key (32-byte Ed25519, base64). Safe to bundle in client builds —
# used only to *verify* license signatures offline. Implicitly mapped to
# `keyId = ed25519-1` (LicenseConstants.keyIdDefault) for legacy/compat.
BACKUP_DATABASE_LICENSE_PUBLIC_KEY=6n1uCgqzBYB5HIuleT6yLgLVTs6NMoepDYyq4xcCZQY=

# Multi-key map (JSON, optional). Allows graceful key rotation: keep the
# old key valid until all clients have migrated, while emitting new
# licenses with the new key. Example:
#   {"ed25519-1": "<base64-32>", "ed25519-2": "<base64-32>"}
# When both PUBLIC_KEY and PUBLIC_KEYS are set, the JSON map takes
# precedence for conflicting `keyId`s.
BACKUP_DATABASE_LICENSE_PUBLIC_KEYS=

# Active keyId for NEW licenses generated locally (admin/debug only).
# Defaults to `ed25519-1`. Set to `ed25519-2` (or another id present in
# PUBLIC_KEYS) after rotation to start emitting with the new key.
BACKUP_DATABASE_LICENSE_ACTIVE_KEY_ID=

# ============================================================================
# !!! SECRETS — NEVER COMMIT REAL VALUES TO THIS FILE !!!
# ============================================================================
# `.env` is bundled as a Flutter asset (see pubspec.yaml). Any value left
# here ends up trivially extractable from the installer/AppImage of every
# client. The keys below MUST stay empty in this file and be provided ONLY
# via the external machine config (preferred for dev / CI):
#
#     C:\ProgramData\BackupDatabase\config\.env
#
# On boot, `EnvironmentLoader` reads that external file first; the bundled
# asset is only a fallback for non-secret keys.
#
# Runtime guard: `EnvironmentLoader` refuses bundled values for any key
# listed in `EnvironmentLoader.forbiddenInBundledAssetKeys` and logs an
# `error` so an accidental commit is caught immediately.
# ============================================================================

# Private key for license generation (base64-encoded 64-byte Ed25519 private key)
# DEBUG/ADMIN MODE ONLY — keep this value in the external config above.
BACKUP_DATABASE_LICENSE_PRIVATE_KEY=

# Admin password for in-app license generator (debug mode only).
# Stored as a salted hash (Argon2-like via crypto.pbkdf2). Plain-text passwords
# are no longer accepted. Use scripts/hash_admin_password.dart to generate.
LICENSE_ADMIN_PASSWORD_HASH=

# Optional: Revocation list (signed JSON with revokedDeviceKeys array)
# Can be base64-encoded JSON or file path via BACKUP_DATABASE_LICENSE_REVOCATION_LIST_PATH
BACKUP_DATABASE_LICENSE_REVOCATION_LIST=
BACKUP_DATABASE_LICENSE_REVOCATION_LIST_PATH=

# ----------------------------------------------------------------------------
# FTP integration tests (real server)
# ----------------------------------------------------------------------------
# These are also secrets — set them in the external machine .env, not here.
FTP_IT_HOST=
FTP_IT_PORT=21
FTP_IT_USER=
FTP_IT_PASS=
FTP_IT_REMOTE_PATH=
