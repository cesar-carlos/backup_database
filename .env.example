APP_NAME=Backup Database
APP_VERSION=2.3.0
DEBUG_MODE=true
AUTO_UPDATE_FEED_URL=https://raw.githubusercontent.com/cesar-carlos/backup_database/main/appcast.xml

# Single Instance Control
# Set to 'false' to allow multiple instances (useful for development/testing)
# Default: true (only one instance allowed)
SINGLE_INSTANCE_ENABLED=true

# UI scheduler fallback when Windows Service status cannot be checked
# fail_open: start local scheduler (default)
# fail_safe: do not start local scheduler
UI_SCHEDULER_FALLBACK_MODE=fail_open

# Debug only: App mode override (server | client)
# Used when running from IDE / flutter run. Ignored in release builds.
# Example: DEBUG_APP_MODE=client to test client UI without reinstalling.
DEBUG_APP_MODE=server

# License Configuration (v2 Ed25519)
# Public key for license validation (base64-encoded 32-byte Ed25519 public key)
# This key is embedded in client builds to verify license signatures offline
# REQUIRED for license validation
BACKUP_DATABASE_LICENSE_PUBLIC_KEY=

# Private key for license generation (base64-encoded 64-byte Ed25519 private key)
# DEBUG/ADMIN MODE ONLY - Never distribute this key to clients
# Leave empty in production client builds
BACKUP_DATABASE_LICENSE_PRIVATE_KEY=

# Admin password for in-app license generator (debug mode only)
LICENSE_ADMIN_PASSWORD=

# Optional: Revocation list (signed JSON with revokedDeviceKeys array)
# Can be base64-encoded JSON or file path via BACKUP_DATABASE_LICENSE_REVOCATION_LIST_PATH
BACKUP_DATABASE_LICENSE_REVOCATION_LIST=
BACKUP_DATABASE_LICENSE_REVOCATION_LIST_PATH=

# FTP integration tests (real server)
# Fill these values to enable real FTP integration tests.
FTP_IT_HOST=
FTP_IT_PORT=21
FTP_IT_USER=
FTP_IT_PASS=
FTP_IT_REMOTE_PATH=
